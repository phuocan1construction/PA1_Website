---

<BaseLayout
  title="Báo giá — PA1 Construction"
  description="Báo giá vật tư xây dựng, vật liệu hoàn thiện và cách tính diện tích xây dựng quy đổi. PA1 Construction minh bạch từ báo giá."
  activePage="bao-gia"
>

  <section class="page-header">
    <div class="wrap">
      <h1>Có khi nào!!!</h1>
      <p>Bạn mua một món tưởng "hời",<br>nhưng khi nhận nó, chỉ muốn vứt nó đi cho xong!!!</p>
    </div>
  </section>

  <!-- Cách tính diện tích -->
  <section>
    <div class="wrap">
      <div class="section-header">
        <h2>Cách tính diện tích xây dựng</h2>
        <p>Hiểu đúng cách quy đổi diện tích để biết chính xác chi phí xây nhà.</p>
      </div>
      <div class="quote-grid" style="max-width: 800px; margin: 0 auto;">
        <div class="quote-card">
          <img src={`${basePath}/1_General/001_CachTinhDienTichXayDung.png`} alt="Cách tính diện tích xây dựng quy đổi" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <!-- Báo giá thiết kế -->
  <section style="background: var(--light);">
    <div class="wrap">
      <div class="quote-category">
        <div class="section-header">
          <h2>Báo giá Thiết kế</h2>
        </div>
        <div class="quote-grid">
          {designQuote.map(item => (
            <div class="quote-card">
              <img src={`${basePath}/${item.src}`} alt={item.label} loading="lazy">
              <div class="quote-label">{item.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Báo giá thi công -->
  <section>
    <div class="wrap">
      <div class="quote-category">
        <div class="section-header">
          <h2>Báo giá Thi công</h2>
          <p>Phần thô, trọn gói, hoàn thiện — chọn gói phù hợp nhu cầu.</p>
        </div>
        <div class="quote-grid">
          {buildQuote.map(item => (
            <div class="quote-card">
              <img src={`${basePath}/${item.src}`} alt={item.label} loading="lazy">
              <div class="quote-label">{item.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Vật tư phần thô -->
  <section style="background: var(--light);">
    <div class="wrap">
      <div class="quote-category">
        <div class="section-header">
          <h2>Vật tư phần thô</h2>
          <p>Thép, xi măng, gạch, bê tông, ống nước, dây điện — các hạng mục kết cấu chính.</p>
        </div>
        <div class="quote-grid">
          {materialStructural.map(item => (
            <div class="quote-card">
              <img src={`${basePath}/1_General/1_Material_Structural/${item.src}`} alt={item.label} loading="lazy">
              <div class="quote-label">{item.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Vật tư hoàn thiện -->
  <section>
    <div class="wrap">
      <div class="quote-category">
        <div class="section-header">
          <h2>Vật tư hoàn thiện</h2>
          <p>Gạch ốp lát, sơn, cửa, thiết bị vệ sinh, đèn, lan can — hoàn thiện công trình.</p>
        </div>
        <div class="quote-grid">
          {materialFinishing.map(item => (
            <div class="quote-card">
              <img src={`${basePath}/1_General/2_Material_Finishing/${item.src}`} alt={item.label} loading="lazy">
              <div class="quote-label">{item.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CtaBand
    title="Cần báo giá chi tiết cho công trình của bạn?"
    description="Liên hệ PA1 để được khảo sát thực tế & báo giá chính xác trong 24 giờ."
    buttonText="Liên hệ báo giá →"
  />

</BaseLayout>
