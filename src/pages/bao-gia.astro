const designQuote = [
  { src: '2_Design/Design_01.jpg', label: 'Báo giá thiết kế (1)' },
  { src: '2_Design/Design_02.jpg', label: 'Báo giá thiết kế (2)' },
];

const buildQuote = [
  { src: '3_Build/01_Structural/Quotation_Structural.jpg', label: 'Thi công phần thô' },
  { src: '3_Build/02_Full/Quotation_Full.jpg', label: 'Thi công trọn gói' },
  { src: '3_Build/03_Finish/Quotation_Finish.jpg', label: 'Thi công hoàn thiện' },
