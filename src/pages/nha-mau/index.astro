---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBand from '../../components/CtaBand.astro';
---

<BaseLayout
  title="Nhà mẫu — PA1 Construction"
  description="Thư viện nhà mẫu PA1: layout theo loại nhà, thiết kế nội thất từng phòng, quy trình thi công chuẩn."
  activePage="nha-mau"
>

  <section class="page-header">
    <div class="wrap">
      <h1>Nhà mẫu</h1>
      <p>Thư viện thiết kế mẫu từ layout tổng thể,<br>nội thất theo từng phòng,<br>đến quy trình thi công.</p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="nha-mau-categories">

        <!-- Layout -->
        <a href="/nha-mau/layout" class="nha-mau-card">
          <img src="/assets/images/design/Living/PK_01-1_HienDai.jpg" alt="Layout nhà mẫu" loading="lazy">
          <div class="card-body">
            <h3>Layout</h3>
            <p>Mặt bằng tổng thể theo từng loại nhà: Gác lửng, Mái Thái, Mái Nhật, Nhà phố, Biệt thự, Căn hộ.</p>
          </div>
        </a>

        <!-- Thiết kế phòng -->
        <a href="/nha-mau/phong" class="nha-mau-card">
          <img src="/assets/images/design/Kitchen/PB_01-1_HienDai.jpg" alt="Thiết kế phòng" loading="lazy">
          <div class="card-body">
            <h3>Thiết kế phòng</h3>
            <p>Phòng khách, phòng bếp, phòng ngủ, WC — thiết kế nội thất theo phong cách đa dạng.</p>
          </div>
        </a>

        <!-- Quy trình thi công -->
        <a href="/nha-mau/quy-trinh" class="nha-mau-card">
          <img src="/assets/images/hero-bg.jpg" alt="Quy trình thi công" loading="lazy">
          <div class="card-body">
            <h3>Quy trình thi công</h3>
            <p>19 hạng mục từ trắc đạc, bê tông, cốt thép đến sơn nước, cửa nhôm, lan can — chuẩn PA1.</p>
          </div>
        </a>

      </div>
    </div>
  </section>

  <CtaBand
    title="Thích mẫu nào? Liên hệ PA1"
    description="PA1 tư vấn miễn phí, điều chỉnh thiết kế theo nhu cầu thực tế của bạn."
    buttonText="Liên hệ tư vấn →"
  />

</BaseLayout>
