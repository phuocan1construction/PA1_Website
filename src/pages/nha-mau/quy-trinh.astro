---

<BaseLayout
  title="Quy trình thi công — PA1 Construction"
  description="22 hạng mục thi công chuẩn PA1 từ trắc đạc, bê tông, cốt thép đến sơn nước, cửa, nghiệm thu, phê duyệt."
  activePage="nha-mau-quy-trinh"
>

  <section class="page-header">
    <div class="wrap">
      <h1>Quy trình thi công</h1>
      <p>22 hạng mục thi công chuẩn PA1 — mỗi công đoạn đều có tiêu chuẩn rõ ràng.</p>
    </div>
  </section>

  <!-- Tiêu chuẩn áp dụng -->
  <section>
    <div class="wrap">
      <div class="section-header">
        <h2>Tiêu chuẩn áp dụng</h2>
        <p>PA1 áp dụng các tiêu chuẩn xây dựng hiện hành, kết hợp quy trình nội bộ được đúc kết từ thực tế công trường.</p>
      </div>
      <div class="quote-grid" style="max-width: 1000px; margin: 0 auto;">
        {standard.map(item => (
          <div class="quote-card">
            <img src={`${basePath}/${item.src}`} alt={item.label} loading="lazy">
            <div class="quote-label">{item.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 22 hạng mục -->
  <section style="background: var(--light);">
    <div class="wrap">
      <div class="section-header">
        <h2>PA1 Standard — 22 hạng mục</h2>
      </div>

      {workflows.map(wf => (
        <div class="project-section">
          <div class="project-section-title">{wf.num}. {wf.name}</div>
          {wf.images.length > 0 ? (
            <div class="quote-grid">
              {wf.images.map(img => (
                <div class="quote-card">
                  <img src={`${basePath}/${img}`} alt={`${wf.name}`} loading="lazy">
                </div>
              ))}
            </div>
          ) : (
            <p style="color: var(--text-light); font-style: italic;">Đang cập nhật...</p>
          )}
        </div>
      ))}
    </div>
  </section>

  <CtaBand
    title="Muốn xem quy trình chi tiết?"
    description="PA1 minh bạch quy trình — liên hệ để nhận tài liệu kỹ thuật."
    buttonText="Liên hệ PA1 →"
  />

</BaseLayout>
